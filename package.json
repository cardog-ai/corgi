{
  "name": "@cardog/corgi",
  "version": "3.0.1-beta.0",
  "description": "High-performance offline VIN decoder. Binary indexes, O(log n) lookup, 7400+ decodes/sec.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "transform": "tsx build/transform.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "tsx test/benchmark.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "better-sqlite3": "^9.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  },
  "keywords": [
    "vin",
    "vin-decoder",
    "automotive",
    "vehicle-identification",
    "nhtsa",
    "vpic",
    "offline",
    "fast",
    "binary-search"
  ],
  "author": {
    "name": "Cardog Team",
    "email": "hello@cardog.ai",
    "url": "https://cardog.ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cardog-ai/corgi.git"
  },
  "bugs": {
    "url": "https://github.com/cardog-ai/corgi/issues"
  },
  "homepage": "https://github.com/cardog-ai/corgi#readme",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
